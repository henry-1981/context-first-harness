{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "storyteller.schema.json",
  "title": "Storyteller agent stdout return",
  "type": "object",
  "required": ["outline_path", "source_type", "slide_count_declared", "slide_count_actual", "slides"],
  "properties": {
    "outline_path": { "type": "string", "pattern": "^draft/outline\\.md$" },
    "source_type": { "type": "string", "enum": ["prepared", "raw", "topic"] },
    "slide_count_declared": { "type": "integer", "minimum": 1 },
    "slide_count_actual": { "type": "integer", "minimum": 0 },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["n", "title", "source_range", "takeaway", "template"],
        "properties": {
          "n": { "type": "integer", "minimum": 1 },
          "title": { "type": "string", "minLength": 1 },
          "source_range": { "type": "string", "pattern": "^(input/input\\.md:\\d+(-\\d+)?|topic)$" },
          "takeaway": { "type": "string", "minLength": 1 },
          "template": { "type": "string" },
          "context": { "type": "string" },
          "fallbacks": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } }
  }
}
