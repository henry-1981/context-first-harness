{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "outline-verifier.schema.json",
  "title": "Outline-verifier agent stdout return",
  "type": "object",
  "required": ["status", "summary_line", "checks", "findings", "retries"],
  "properties": {
    "status": { "type": "string", "enum": ["pass", "warn", "fail"] },
    "summary_line": { "type": "string", "pattern": "^PASS \\d+ / WARN \\d+ / FAIL \\d+$" },
    "checks": {
      "type": "object",
      "required": ["slide_count_match", "takeaway_present", "message_dedup", "image_placeholder_path", "paraphrase_token_overlap", "footer_tag_consistent"],
      "properties": {
        "slide_count_match": { "type": "string", "enum": ["pass", "fail"] },
        "takeaway_present": { "type": "string", "enum": ["pass", "fail"] },
        "message_dedup": { "type": "string", "enum": ["pass", "warn", "fail"] },
        "image_placeholder_path": { "type": "string", "enum": ["pass", "fail", "n/a"] },
        "paraphrase_token_overlap": { "type": "string", "enum": ["pass", "warn", "fail"] },
        "footer_tag_consistent": { "type": "string", "enum": ["pass", "warn"] }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check", "severity"],
        "properties": {
          "check": { "type": "string" },
          "severity": { "type": "string", "enum": ["warn", "fail"] },
          "evidence_path": { "type": "string", "pattern": "draft/outline\\.md(:\\d+(-\\d+)?)?$" },
          "quote": { "type": "string", "minLength": 5, "maxLength": 30 },
          "token_overlap_ratio": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "anyOf": [
          { "required": ["evidence_path"] },
          { "required": ["quote"] }
        ]
      }
    },
    "retries": { "type": "integer", "minimum": 0 },
    "warnings": { "type": "array", "items": { "type": "string" } }
  }
}
