{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/block-template-write.py",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/session-start-handoff-scan.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/session-start-context-inject.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/wiki-check.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
